# Application
APP_PORT=8080
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Telegram
TELEGRAM_BOT_TOKEN=

# Optional integrations
